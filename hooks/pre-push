#!/bin/sh
# Reject direct pushes to main. Use a feature branch + PR.
#
# Activate this hook in a fresh clone with:
#   git config core.hooksPath hooks
#
# Bypass once with `git push --no-verify` if you genuinely need to.
# Server-side ruleset on GitHub will still reject the push, so this
# hook is just for a faster, clearer local error.

protected="refs/heads/main"
exit_code=0

while read -r local_ref local_oid remote_ref remote_oid; do
  if [ "$remote_ref" = "$protected" ]; then
    echo "" >&2
    echo "Blocked: direct push to main." >&2
    echo "" >&2
    echo "Use a PR:" >&2
    echo "  git checkout -b <topic>" >&2
    echo "  git push -u origin <topic>" >&2
    echo "  gh pr create --fill" >&2
    echo "" >&2
    exit_code=1
  fi
done

exit "$exit_code"
